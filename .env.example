# URL do repositório público de skills no GitHub
SKILLS_REPO_URL=https://github.com/sua-org/seu-repo-de-skills.git

# Intervalo de sincronização automática (em minutos)
SYNC_INTERVAL_MINUTES=60

# Caminhos internos ao container (normalmente não precisa alterar)
REPO_LOCAL_PATH=/app/repo
DATABASE_PATH=/app/data/skills.db
